---
/**
 * PocketForms — Astro snippet.
 *
 * Drop this anywhere in your Astro site and pass props for the form
 * slug + (optionally) the PocketBase URL if you don't want to set
 * window.POCKETFORMS_URL globally.
 *
 * The SDK script is loaded with `is:inline` so it ships with the page;
 * drop the `is:inline` if you'd rather host the bundle on your CDN.
 */
interface Props {
  slug: string;
  pocketbaseUrl?: string;
  mode?: "ajax" | "classic";
  redirect?: string;
  turnstileSiteKey?: string;
  class?: string;
}

const {
  slug,
  pocketbaseUrl = import.meta.env.PUBLIC_POCKETFORMS_URL,
  mode = "ajax",
  redirect,
  turnstileSiteKey,
  class: className,
} = Astro.props;
---

<form
  class={className}
  data-pocketforms={slug}
  data-pocketforms-mode={mode}
  data-pocketforms-url={pocketbaseUrl}
  data-pocketforms-redirect={redirect}
  data-pocketforms-turnstile={turnstileSiteKey}
>
  <slot />
</form>

<script src="https://cdn.jsdelivr.net/npm/@pocketforms/client/dist/pocketforms.iife.js" is:inline></script>

