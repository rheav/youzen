<script is:inline>
  // ─── Scroll-spy ────────────────────────────────────────────────────
  // Highlight the sidebar link whose section is closest to the top of
  // the viewport. We track all data-spy ids by querying their target
  // sections and using IntersectionObserver with a top-anchored
  // rootMargin so the active link flips when the section's top crosses
  // ~120 px from the top of the viewport.
  (function () {
    const links = Array.from(
      document.querySelectorAll(".docs-nav-link[data-spy]"),
    );
    if (!links.length) return;

    const byId = new Map();
    const ids = links
      .map((a) => {
        const id = a.getAttribute("data-spy");
        const section = id ? document.getElementById(id) : null;
        if (id && section) {
          byId.set(id, a);
          return id;
        }
        return null;
      })
      .filter(Boolean);

    function setActive(id) {
      for (const a of links) a.removeAttribute("aria-current");
      const active = byId.get(id);
      if (active) active.setAttribute("aria-current", "true");
    }

    // Track which sections are currently intersecting the activation band.
    const visible = new Set();
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) visible.add(entry.target.id);
          else visible.delete(entry.target.id);
        }
        // Of the visible ones, pick the topmost in document order.
        for (const id of ids) {
          if (visible.has(id)) {
            setActive(id);
            return;
          }
        }
        // Nothing in the band: keep last-active (or fall back to first).
      },
      {
        // Activation band: top 35 % of the viewport. Sections above the
        // band count as "passed"; below the band don't count yet.
        rootMargin: "-15% 0px -65% 0px",
        threshold: 0,
      },
    );

    for (const id of ids) {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    }

    // First-paint default: highlight whatever is at the current scroll
    // position (deep-link case).
    requestAnimationFrame(() => {
      if (!document.querySelector(".docs-nav-link[aria-current='true']")) {
        setActive(ids[0]);
      }
    });
  })();
</script>
