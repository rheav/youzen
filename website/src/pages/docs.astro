    border-radius: 1rem;
    padding: 1.25rem 1.4rem;
    backdrop-filter: blur(4px);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.02);
  }

  .docs-card-title {
    color: var(--color-ink);
    font-size: 0.95rem;
    font-weight: 500;
  }

  .docs-list {
    margin-top: 0.5rem;
    padding-left: 1.1rem;
    list-style: disc;
    color: rgb(87, 83, 78); /* stone-600 */
    font-size: 0.9rem;
