---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import {
  BookOpen,
  Rocket,
  LayoutGrid,
  Tv,
  ShieldOff,
  Pause,
  Lock,
  ScrollText,
} from "@lucide/astro";

/**
 * /docs — full reference for every youZen feature and toggle.
 *
 * Layout:
 *   - Sticky left sidebar (desktop) with section links + scroll-spy.
 *   - Single-column main content; sections each own a stable id used by
 *     both anchor links and the IntersectionObserver below.
 *
 * The structure mirrors `extension/src/config/features.js`, which is the
 * single source of truth in the extension. Update this page whenever a
 * toggle is added, removed, or renamed there.
 */

const sidebar = [
  { id: "quick-start", label: "Quick start", icon: Rocket },
  { id: "feeds", label: "Feeds", icon: LayoutGrid },
  { id: "watch", label: "Watch", icon: Tv },
  { id: "blocklist", label: "Blocklist", icon: ShieldOff },
  { id: "global", label: "Pause & global", icon: Pause },
  { id: "privacy", label: "Privacy", icon: Lock },
  { id: "changelog", label: "Changelog", icon: ScrollText },
];

const sections = [
  {
    id: "feeds",
    tab: "Feeds",
    intro:
      "Everything you see before you click a video — homepage, sidebar, search, and the navigation chrome.",
    groups: [
      {
        id: "hide-shorts",
        title: "Hide Shorts across YouTube",
        master: "hideShorts",
        summary:
          "One master toggle that flips every Shorts surface at once, plus per-surface toggles if you want to keep one and kill the rest.",
        features: [
          {
            id: "hideHomeShorts",
            label: "Homepage Shorts shelves",
            default: "On",
            kind: "CSS",
            body: "Removes the dedicated Shorts shelves on the homepage feed (the rows with vertical thumbnails). Regular videos around them stay where they are; the feed just reflows.",
          },
          {
            id: "hideNavShorts",
            label: "Left sidebar nav",
            default: "On",
            kind: "CSS",
            body: "Hides the Shorts entry in the left sidebar nav so you cannot accidentally click into the Shorts surface from there.",
          },
          {
            id: "hideChannelShortsTab",
            label: "Channel Shorts tab",
            default: "On",
            kind: "CSS",
            body: "On a creator's channel page, the row of tabs (Home / Videos / Shorts / Live / Playlists / Community) loses its Shorts entry.",
          },
          {
            id: "hideSearchShorts",
            label: "Search results",
            default: "On",
            kind: "CSS",
            body: "Search results stop showing Shorts shelves and individual Shorts cards. You see videos, channels, and playlists only.",
          },
          {
            id: "hideSubsShorts",
            label: "Subscriptions feed",
            default: "On",
            kind: "CSS",
            body: "Strips Shorts from your Subscriptions feed so it stays a chronological list of long-form uploads from the channels you actually follow.",
          },
        ],
      },
      {
        id: "declutter-home",
        title: "Declutter homepage",
        master: "declutterHome",
        summary:
          "The homepage feed is the loudest surface on YouTube. Pick what shows there — or replace it entirely.",
        features: [
          {
            id: "hideHomeFeed",
            label: "Hide homepage feed",
            default: "Off",
            kind: "Hybrid",
            body: "Hides the main grid of thumbnails on youtube.com. When enabled, you choose what shows in its place via the dropdown next to the toggle:",
            extras: [
              {
                value: "Empty",
                body: "Just whitespace where the feed used to be. The cleanest option — useful if you only ever come to YouTube via direct links.",
              },
              {
                value: "Quick links card",
                body: "A small card with one-tap entries for Subscriptions, History, Playlists, and Watch Later. Default option.",
              },
              {
                value: "Redirect to Subscriptions",
                body: "Whenever you load the homepage, the extension immediately navigates to /feed/subscriptions so you skip the algorithmic feed entirely.",
              },
            ],
          },
          {
            id: "hideChipBar",
            label: "Chip / category bar",
            default: "Off",
            kind: "CSS",
            body: "Hides the row of pill-shaped chips at the top of the homepage (All, Music, Gaming, News, Live, …). They are a category re-ranker, not a real navigation control.",
          },
          {
            id: "hideBreakingShelves",
            label: "Breaking news & featured shelves",
            default: "Off",
            kind: "CSS",
            body: "Removes the Breaking News and similar editorial shelves that occasionally appear at the top of the feed.",
          },
        ],
      },
      {
        id: "declutter-search",
        title: "Declutter search",
        master: "declutterSearch",
        summary:
          "Make search behave like a search engine: a list of videos that match your query, nothing else.",
        features: [
          {
            id: "hideSearchMixedShelves",
            label: '"People also watched" & mixed shelves',
            default: "Off",
            kind: "CSS",
            body: 'Drops the inline shelves YouTube splices into search results — "People also watched", "From related searches", "For you", and similar — so the result list stays a single column of relevant videos.',
          },
        ],
      },
      {
        id: "nav-chrome",
        title: "Navigation chrome",
        master: null,
        summary:
          "Standalone toggles for the global YouTube UI elements that follow you across every page.",
        features: [
          {
            id: "hideLeftSidebar",
            label: "Hide left sidebar entirely",
            default: "Off",
            kind: "CSS",
            body: "Hides the entire left navigation rail. Aggressive — only enable this if you reach playlists, history, and subscriptions through bookmarks or the homepage replacement.",
          },
          {
            id: "hideNotificationBell",
            label: "Hide notification bell",
            default: "Off",
            kind: "CSS",
            body: "Removes the bell icon in the YouTube masthead. The bell is a standing invitation to interrupt yourself; this turns it off without unsubscribing from notifications.",
          },
          {
            id: "hideTrending",
            label: "Hide trending / explore",
            default: "Off",
            kind: "CSS",
            body: "Hides the Trending and Explore entries in the left sidebar so you cannot fall into a curated rabbit hole.",
          },
          {
            id: "hideCreateButton",
            label: 'Hide "Create" button in navbar',
            default: "On",
            kind: "CSS",
            body: "Removes the top-bar Create / upload button. If you do not run a channel, the button is just visual noise.",
          },
        ],
      },
    ],
  },
  {
    id: "watch",
    tab: "Watch",
    intro:
      "Everything around the player on a /watch page — comments, related videos, the action bar, and the description.",
    groups: [
      {
        id: "comments-area",
        title: "Hide comments area",
        master: "commentsArea",
        summary:
          "The comments and live chat boxes are the noisiest part of any video page. Hide them entirely or keep one and drop the other.",
        features: [
          {
            id: "hideComments",
            label: "Comments",
            default: "Off",
            kind: "CSS",
            body: "Hides the comments section on regular videos. Comments don't even render — there is nothing to scroll past.",
          },
          {
            id: "hideLiveChat",
            label: "Live chat",
            default: "Off",
            kind: "CSS",
            body: "Hides the live chat panel on premieres and livestreams so you can watch the stream without the chat firehose in your peripheral vision.",
          },
        ],
      },
      {
        id: "declutter-watch",
        title: "Declutter player surroundings",
        master: "declutterWatch",
        summary:
          "Strip the watch page back to a video and a title. Each toggle is independent — turn off the master to flip them all at once.",
        features: [
          {
            id: "hideRelatedVideos",
            label: "Related videos sidebar",
            default: "Off",
            kind: "CSS",
            body: "Hides the up-next sidebar on the right of the player. The video plays full-width on wide screens; on narrow screens the empty column is just removed.",
          },
          {
            id: "hideEndScreenCards",
            label: "End-screen cards",
            default: "On",
            kind: "CSS",
            body: "Hides the cards that overlay the last 5–20 seconds of a video pushing related videos. The video ends when the video ends.",
          },
          {
            id: "hideAutoplayToggle",
            label: "Up-next autoplay toggle",
            default: "On",
            kind: "CSS",
            body: 'Removes the autoplay switch from the player controls. Combine with "Related videos sidebar" off to make autoplay practically unreachable.',
          },
          {
            id: "hideMerchShelves",
            label: "Merch & ticket shelves",
            default: "On",
            kind: "CSS",
            body: "Hides the merch, ticket, and product shelves YouTube injects below videos.",
          },
          {
            id: "hideJoinButton",
            label: 'Hide "Join" / member button',
            default: "On",
            kind: "CSS",
            body: 'Removes the channel-membership "Join" button next to Subscribe. You can still join from the channel page if you ever decide to.',
          },
          {
            id: "hideSubscribeBell",
            label: "Hide notification bell",
            default: "On",
            kind: "CSS",
            body: "Hides the bell icon next to the Subscribe button on a video page. Subscribe stays — just the bell goes.",
          },
          {
            id: "hideWatchActions",
            label: "Hide action buttons",
            default: "On",
            kind: "CSS",
            body: "Hides the Share / Save / Ask / Clip action bar under the video. Like and dislike are controlled separately by the next toggle.",
          },
          {
            id: "hideLikeDislike",
            label: "Hide like / dislike",
            default: "On",
            kind: "CSS",
            body: "Hides the like and dislike buttons and their counts. If a number is going to colour your judgement of a video, this stops it.",
          },
          {
            id: "hideDescription",
            label: "Collapse description by default",
            default: "Off",
            kind: "Hybrid",
            body: "Forces the description to render in its collapsed state. CSS clamps it on first paint; a tiny JS step re-collapses it if YouTube hydrates it expanded. Click the description to read it normally.",
          },
        ],
      },
      {
        id: "watch-loose",
        title: "Other watch behaviors",
        master: null,
        summary: "Standalone watch-page toggles that don't fit a group.",
        features: [
          {
            id: "redirectShorts",
            label: "Redirect Shorts to normal video page",
            default: "On",
            kind: "JS",
            body: "When you open a /shorts/<id> URL, the extension immediately navigates to /watch?v=<id>. You get the regular player, full controls, and no vertical-scroll cage. The redirect uses location.replace so Back goes wherever you came from, not back into Shorts.",
          },
        ],
      },
    ],
  },
  {
    id: "blocklist",
    tab: "Blocklist",
    intro:
      "Two lists of rules — one for keywords, one for channels — that hide matching cards everywhere youZen runs.",
    groups: [
      {
        id: "blocklist-rules",
        title: "Rules",
        master: null,
        summary:
          "Add a rule from the Blocklist tab in the sidepanel, or right-click any selected text on YouTube to drop it into the keyword or channel list directly.",
        features: [
          {
            id: "blocklistKeywords",
            label: "Keyword rules",
            default: "Empty",
            kind: "JS",
            body: "Match against a card's title text. Each rule has a mode and a case-sensitivity flag.",
            extras: [
              {
                value: "Substring",
                body: "Matches if the title contains the rule text anywhere. Default mode — case-insensitive unless you turn that on.",
              },
              {
                value: "Whole word",
                body: 'Matches only when the rule text appears as a complete word — useful for short, common terms ("AI" without matching "Brain").',
              },
              {
                value: "Regex",
                body: "Matches a JavaScript regular expression. Invalid patterns are silently ignored so a typo never breaks the feed.",
              },
            ],
          },
          {
            id: "blocklistChannels",
            label: "Channel rules",
            default: "Empty",
            kind: "JS",
            body: "Match against the channel name or @handle on each card. Same three modes — substring, whole-word, regex — and the same case-sensitivity option.",
          },
        ],
      },
      {
        id: "blocklist-howto",
        title: "How matching works",
        master: null,
        summary: "What gets scanned, when, and what happens to matches.",
        features: [
          {
            id: "scope",
            label: "Where rules apply",
            default: "All feeds",
            kind: "Info",
            body: "Homepage, Subscriptions, search results, the Watch page sidebar, channel pages, and any other surface that uses YouTube's standard video card components. The scanner runs at document_start and re-runs on every DOM mutation, so infinite scroll is covered.",
          },
          {
            id: "effect",
            label: "What a block does",
            default: "Hide",
            kind: "Info",
            body: "Matched cards get a data-ytc-blocked attribute and are hidden via CSS. The card stays in the DOM (so YouTube does not try to refill the slot) but takes up no space and does not respond to hover or clicks.",
          },
          {
            id: "right-click",
            label: "Right-click to add",
            default: "On",
            kind: "Info",
            body: 'Highlight any text on a YouTube page and right-click — the menu shows "youZen: Block \u201c…\u201d as keyword" and "youZen: Block channel \u201c…\u201d". Both append a substring rule with case-insensitive matching, idempotent against duplicates.',
          },
        ],
      },
    ],
  },
  {
    id: "global",
    tab: "Pause & global controls",
    intro:
      "The toggles that aren't per-feature: pausing youZen on a tab or globally, and resetting your settings.",
    groups: [
      {
        id: "pause",
        title: "Pause",
        master: null,
        summary:
          "Two ways to switch youZen off without losing your settings. Both kill every CSS rule and every JS behavior — the page reverts to vanilla YouTube until you flip them back.",
        features: [
          {
            id: "tabPause",
            label: "Per-tab pause",
            default: "Off",
            kind: "Session",
            body: 'Right-click anywhere on a YouTube page and choose "Pause youZen on this tab". The pause lives in chrome.storage.session, so it lasts as long as the tab does and clears when the tab closes. Only the active tab is affected; other tabs keep their settings.',
          },
          {
            id: "globallyPaused",
            label: "Global kill-switch",
            default: "Off",
            kind: "Persistent",
            body: 'The big toggle in the sidepanel header. Disables youZen on every YouTube tab, in every window, until you flip it back. Settings, blocklists, and per-toggle state all stay exactly as you left them — pause is purely "stop applying", not "forget".',
          },
        ],
      },
      {
        id: "appearance",
        title: "Appearance",
        master: null,
        summary:
          "The sidepanel respects your system theme by default and remembers any explicit choice across sessions.",
        features: [
          {
            id: "theme",
            label: "Light / dark theme",
            default: "Auto (system)",
            kind: "Persistent",
            body: 'Click the gear icon in the sidepanel header to toggle dark mode. Until you make a choice, the panel follows prefers-color-scheme; once you pick a side, that choice is stored under "appTheme" and used everywhere.',
          },
        ],
      },
      {
        id: "reset",
        title: "Reset",
        master: null,
        summary: "Start fresh.",
        features: [
          {
            id: "reset",
            label: "Reset to defaults",
            default: "—",
            kind: "Action",
            body: "Wipes every youZen-managed key in chrome.storage.local and re-seeds the install defaults. Your blocklist is cleared, every toggle returns to its default state, and the global pause flips back off. There is no undo; the action is local — nothing is sent anywhere.",
          },
        ],
      },
    ],
  },
];

const kindBadge = (kind: string) => {
  const map: Record<string, string> = {
    CSS: "bg-leaf-mist text-stone-700",
    JS: "bg-pistachio text-stone-800",
    Hybrid: "bg-iris-soft text-stone-700",
    Session: "bg-stone-100 text-stone-700",
    Persistent: "bg-stone-100 text-stone-700",
    Action: "bg-stone-100 text-stone-700",
    Info: "bg-stone-100 text-stone-500",
  };
  return map[kind] ?? "bg-stone-100 text-stone-700";
};
---

<Layout
  title="Docs — youZen"
  description="Every toggle in youZen, what it does, and what it changes on YouTube. No tracking, no telemetry, no remote configuration."
>
  <Navbar />

  <div class="docs-shell relative z-10 mx-auto max-w-6xl px-4 pt-28 pb-16 md:px-6 md:pt-36">
    <div class="docs-grid">
      <!-- ─── Sidebar ─── -->
      <aside class="docs-sidebar" aria-label="Docs navigation">
        <div class="docs-sidebar-inner">
          <a
            href="/docs"
            class="text-leaf-deep flex items-center gap-2 pb-5 text-base font-medium tracking-tight"
          >
            <BookOpen size={18} stroke-width={2} />
            <span>Docs</span>
          </a>

          <nav>
            <ul class="space-y-1 text-sm">
              {
                sidebar.map((item) => {
                  const Icon = item.icon;
                  return (
                    <li>
                      <a
                        href={`#${item.id}`}
                        data-spy={item.id}
                        class="docs-nav-link group flex items-center gap-2.5 rounded-lg px-3 py-2 text-stone-500 transition-colors"
                      >
                        <Icon size={15} stroke-width={1.8} class="docs-nav-icon shrink-0" />
                        <span>{item.label}</span>
                      </a>
                    </li>
                  );
                })
              }
            </ul>
          </nav>

          <div class="mt-8 border-t border-stone-200/70 pt-5 text-xs text-stone-400">
            <p class="leading-relaxed">
              Every toggle, in plain language. Mirrors what's in the
              extension's feature registry.
            </p>
          </div>
        </div>
      </aside>

      <!-- ─── Main ─── -->
      <article class="docs-main">
        <!-- Hero -->
        <header class="reveal mb-12">
          <h1 class="text-ink text-4xl font-medium tracking-tight md:text-5xl">
            <span class="text-leaf-deep">youZen</span> Docs
          </h1>
          <p class="mt-4 max-w-2xl text-lg leading-relaxed text-stone-600">
            One sidepanel and a small pile of switches. Here's what each one
            does, what it changes on the page, and what happens when you flip
            it. Nothing is remote-configurable — what's documented is what
            runs in your browser.
          </p>
        </header>

        <!-- Quick start -->
        <section
          id="quick-start"
          class="reveal mb-16 scroll-mt-28"
          aria-labelledby="quick-start-title"
        >
          <header class="mb-6 flex items-center gap-3">
            <span class="docs-section-icon">
              <Rocket size={18} stroke-width={2} />
            </span>
            <h2
              id="quick-start-title"
              class="text-ink text-2xl font-medium tracking-tight md:text-3xl"
            >
              Quick start
            </h2>
          </header>

          <p class="mb-5 max-w-2xl text-stone-600">
            youZen is a Chrome extension that quiets YouTube. Install it,
            open the side panel, and start flipping switches.
          </p>

          <div class="grid gap-4 md:grid-cols-2">
            <div class="docs-card">
              <h3 class="docs-card-title">Install</h3>
              <ol class="docs-list">
                <li>Add youZen from the Chrome Web Store.</li>
                <li>Pin it to your toolbar so the icon stays visible.</li>
                <li>Click the leaf icon to open the side panel.</li>
                <li>Defaults are sensible — flip what you want.</li>
              </ol>
            </div>
            <div class="docs-card">
              <h3 class="docs-card-title">Where things live</h3>
              <ul class="docs-list">
                <li>
                  <strong class="text-ink">Feeds tab</strong> — homepage,
                  search, sidebar, navigation chrome.
                </li>
                <li>
                  <strong class="text-ink">Watch tab</strong> — comments,
                  related, action buttons, description.
                </li>
                <li>
                  <strong class="text-ink">Blocklist tab</strong> — keyword
                  and channel rules.
                </li>
                <li>
                  <strong class="text-ink">Header</strong> — global pause
                  and theme.
                </li>
              </ul>
            </div>
          </div>
        </section>

        <!-- Feature sections from registry -->
        {
          sections.map((s) => (
            <section
              id={s.id}
              class="reveal mb-20 scroll-mt-28"
              aria-labelledby={`${s.id}-title`}
            >
              <header class="mb-6 flex items-center gap-3 border-b border-stone-200/70 pb-4">
                <span class="docs-section-icon">
                  {s.id === "feeds" && <LayoutGrid size={18} stroke-width={2} />}
                  {s.id === "watch" && <Tv size={18} stroke-width={2} />}
                  {s.id === "blocklist" && (
                    <ShieldOff size={18} stroke-width={2} />
                  )}
                  {s.id === "global" && <Pause size={18} stroke-width={2} />}
                </span>
                <h2
                  id={`${s.id}-title`}
                  class="text-ink text-2xl font-medium tracking-tight md:text-3xl"
                >
                  {s.tab}
                </h2>
              </header>

              <p class="mb-8 max-w-2xl text-stone-600">{s.intro}</p>

              {s.groups.map((g) => (
                <section
                  id={`${s.id}-${g.id}`}
                  class="mb-10 scroll-mt-28"
                  aria-labelledby={`${s.id}-${g.id}-title`}
                >
                  <header class="mb-4">
                    <h3
                      id={`${s.id}-${g.id}-title`}
                      class="text-ink mb-1.5 text-lg font-medium tracking-tight md:text-xl"
                    >
                      {g.title}
                      {g.master && (
                        <span class="bg-sage ml-3 align-middle rounded-full px-2.5 py-0.5 text-[10px] font-medium tracking-wider text-stone-600 uppercase">
                          master
                        </span>
                      )}
                    </h3>
                    <p class="max-w-2xl text-sm text-stone-500">{g.summary}</p>
                  </header>

                  <ul class="space-y-3">
                    {g.features.map((f) => (
                      <li class="docs-card">
                        <div class="mb-2 flex flex-wrap items-baseline gap-x-3 gap-y-1">
                          <h4 class="text-ink text-base font-medium">
                            {f.label}
                          </h4>
                          <code class="rounded bg-stone-100 px-1.5 py-0.5 font-mono text-[11px] text-stone-500">
                            {f.id}
                          </code>
                          <span
                            class={`rounded-full px-2 py-0.5 text-[10px] font-medium tracking-wider uppercase ${kindBadge(f.kind)}`}
                          >
                            {f.kind}
                          </span>
                          <span class="ml-auto text-xs text-stone-400">
                            Default:{" "}
                            <span class="text-stone-600">{f.default}</span>
                          </span>
                        </div>
                        <p class="text-sm leading-relaxed text-stone-600">
                          {f.body}
                        </p>
                        {f.extras && (
                          <ul class="mt-4 space-y-2 border-l-2 border-stone-200/80 pl-4">
                            {f.extras.map((x) => (
                              <li>
                                <p class="text-ink text-sm font-medium">
                                  {x.value}
                                </p>
                                <p class="text-sm text-stone-500">{x.body}</p>
                              </li>
                            ))}
                          </ul>
                        )}
                      </li>
                    ))}
                  </ul>
                </section>
              ))}
            </section>
          ))
        }

        <!-- Privacy -->
        <section
          id="privacy"
          class="reveal mb-20 scroll-mt-28"
          aria-labelledby="privacy-title"
        >
          <header class="mb-6 flex items-center gap-3 border-b border-stone-200/70 pb-4">
            <span class="docs-section-icon">
              <Lock size={18} stroke-width={2} />
            </span>
            <h2
              id="privacy-title"
              class="text-ink text-2xl font-medium tracking-tight md:text-3xl"
            >
              Privacy
            </h2>
          </header>

          <div class="docs-card">
            <h3 class="docs-card-title">Nothing leaves your browser.</h3>
            <p class="mt-2 text-stone-600">
              youZen makes zero external network requests. There is no
              analytics, no telemetry, no remote configuration, no crash
              reporter, no error beacon. The extension does not register an
              account and does not sync settings across devices.
            </p>
            <p class="mt-3 text-stone-600">
              Every toggle on this page is stored in <code
                class="rounded bg-stone-100 px-1.5 py-0.5 font-mono text-[11px] text-stone-700"
                >chrome.storage.local</code
              >; per-tab pause lives in <code
                class="rounded bg-stone-100 px-1.5 py-0.5 font-mono text-[11px] text-stone-700"
                >chrome.storage.session</code
              > and clears when the tab closes. Both are browser-local and
              visible only to the extension itself.
            </p>
            <p class="mt-3 text-stone-600">
              The source is on GitHub — you can read every line, including
              the test that asserts no analytics keys ship in the install
              defaults.
            </p>
          </div>
        </section>

        <!-- Changelog -->
        <section
          id="changelog"
          class="reveal mb-12 scroll-mt-28"
          aria-labelledby="changelog-title"
        >
          <header class="mb-6 flex items-center gap-3 border-b border-stone-200/70 pb-4">
