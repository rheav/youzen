---
import { Play } from "@lucide/astro";
import ChromeButton from "./ChromeButton.astro";
---

<section
  class="relative isolate flex min-h-[72vh] w-full items-center justify-center overflow-x-clip px-6 pt-20 pb-10 md:pt-24 md:pb-12"
>
  <!-- Soft background blobs — positions kept comfortably inside the viewport
       so the blob + its blur radius never hits the window edge. The `.blob`
       class applies a soft radial mask in global.css that fades the edges. -->
  <div
    class="blob"
    aria-hidden="true"
    style="top: 6%; left: 4%; width: 420px; height: 420px; background: #D4E5CD;"
  >
  </div>
  <div
    class="blob blob-alt"
    aria-hidden="true"
    style="bottom: -4%; right: 4%; width: 460px; height: 460px; background: #E6E6FA;"
  >
  </div>

  <div
    class="reveal-group relative z-10 mx-auto flex max-w-3xl flex-col items-center text-center"
  >
    <span
      class="reveal mb-6 inline-flex items-center gap-2 rounded-full border border-stone-200 bg-white/60 px-3 py-1 text-xs font-medium text-stone-500 shadow-softly backdrop-blur-sm"
    >
      <span
        class="block h-1.5 w-1.5 rounded-full"
        style="background-color: #A8C9A0;"></span>
      A quieter way to watch
    </span>

    <h1
      class="reveal text-ink text-5xl leading-[1.04] font-medium tracking-tight md:text-6xl lg:text-[72px]"
    >
      Your YouTube,
      <span
        class="sway mt-1 block text-[1.15em] leading-none"
        style="font-family: var(--font-cursive); color: var(--color-leaf-deep); font-weight: 500;"
      >
        softer
      </span>
      than you remember.
    </h1>

    <p
      class="reveal text-muted mx-auto mt-7 max-w-[500px] text-base md:text-lg"
    >
      Hide Shorts, silence comments, block the chaos. youZen turns YouTube into
      the quiet little corner it used to be — without uninstalling your favorite
      channels.
    </p>

    <div class="reveal mt-9 flex flex-col items-center gap-3 sm:flex-row">
      <ChromeButton>Add to your browser</ChromeButton>
      <a
        href="#preview"
        class="secondary-cta inline-flex items-center gap-2 rounded-full border border-stone-200 bg-white/70 px-6 py-3 text-sm font-medium text-ink backdrop-blur-sm transition-all hover:border-stone-300 hover:bg-white"
      >
        <Play size={14} class="secondary-cta-icon" />
        See it in action
      </a>
    </div>

    <p class="reveal mt-8 text-xs text-stone-400">
      Free · no account · works offline · open source
    </p>
  </div>
</section>
