---
const scenarios = [
  {
    time: "08:14",
    text: "You open YouTube to check one recipe.",
    accent: "#a8c9a0",
  },
  {
    time: "08:17",
    text: "Three Shorts later, you forget what you came for.",
    accent: "#c6d8a9",
  },
  {
    time: "08:23",
    text: "A comment makes your chest tighten a little.",
    accent: "#d4e5cd",
  },
  {
    time: "08:31",
    text: 'The "Up Next" sidebar is louder than your kitchen.',
    accent: "#e8efe8",
  },
  {
    time: "08:40",
    text: "You close the tab without watching the recipe.",
    accent: "#c6d8a9",
  },
  {
    time: "09:02",
    text: "Tomorrow, it could all be quieter.",
    accent: "#7fa87f",
  },
];
---

<section id="scenarios" class="relative overflow-x-clip px-6 py-14 md:py-20">
  <div
    class="mx-auto grid max-w-6xl items-start gap-12 md:grid-cols-[1.2fr_1fr] md:gap-20"
  >
    <!-- Cards (left) -->
    <ol
      class="reveal-group order-2 grid grid-cols-1 gap-4 sm:grid-cols-2 md:order-1 md:gap-5"
    >
      {
        scenarios.map((s, i) => (
          <li
            class="reveal group relative flex min-h-[160px] flex-col justify-between rounded-[1.75rem] border border-stone-100 bg-white p-5 shadow-softly transition-transform duration-500 hover:-translate-y-0.5"
            style={`--stagger: ${i * 60}ms;`}
          >
            <div class="flex items-center gap-2">
              <span
                class="block h-2 w-2 rounded-full"
                style={`background-color: ${s.accent};`}
              />
              <span class="text-sm font-medium text-stone-400">{s.time}</span>
            </div>
            <p
              class="mt-4 text-base leading-snug text-stone-800 transition-colors duration-500 group-hover:text-[color:var(--accent)] md:text-lg"
              style={`--accent: ${s.accent};`}
            >
              {s.text}
            </p>
          </li>
        ))
      }
    </ol>

    <!-- Heading (right, sticky on desktop) -->
    <div
      class="reveal-group order-1 md:order-2 md:sticky md:top-32 md:self-start md:text-left"
    >
      <span
        class="reveal text-xs font-medium tracking-widest text-stone-400 uppercase"
      >
        A familiar evening
      </span>
      <h2 class="reveal mt-3 text-3xl font-medium tracking-tight md:text-5xl">
        Maybe you've had
        <span
          class="text-[1.05em] leading-none"
          style="font-family: var(--font-cursive); color: var(--color-leaf-deep); font-weight: 400;"
        >
          this
        </span>
        evening.
      </h2>
      <p class="reveal text-muted mt-5 max-w-md text-base md:text-lg">
        A quiet timeline of small moments that pile up. If any of them feel like
        yours, you're exactly who we built this for.
      </p>

      <!-- A tiny "signed" tag to carry the Softly handwritten warmth. -->
      <p
        class="reveal mt-10 hidden text-2xl leading-none text-stone-500 md:block"
        style="font-family: var(--font-cursive); font-weight: 400;"
      >
        — most of us, lately.
      </p>
    </div>
  </div>
</section>
