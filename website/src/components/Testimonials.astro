---
const entries = [
  {
    date: "Thursday, 9:47pm",
    text: "First night I didn't fall into a Shorts tunnel. I watched the one cooking video I opened YouTube for, closed the tab, and actually made dinner. Small thing. Felt huge.",
    signature: "Ana, a reformed scroller",
    tilt: "-1deg",
  },
  {
    date: "Sunday morning",
    text: "I didn't realize how loud the comments section was until I turned it off. It's quiet now. My brain is quiet now. Like putting away a radio I didn't know was on.",
    signature: "Jules, Berlin",
    tilt: "1deg",
  },
  {
    date: "A rainy Tuesday",
    text: "Blocked three words — 'reaction', 'prank', 'drama'. My home feed basically exhaled. I forgot YouTube could look like this. Thank you for making it okay again.",
    signature: "Mateus, São Paulo",
    tilt: "-1deg",
  },
  {
    date: "Late. too late.",
    text: "The little breathe button before a video is the silliest thing and also the reason I am asleep by midnight now. I did not know I needed permission to pause.",
    signature: "Harper, a night owl",
    tilt: "1deg",
  },
];
---

<section id="diary" class="relative px-6 py-24 md:py-32">
  <div class="reveal-group mx-auto max-w-3xl text-center">
    <span
      class="reveal text-xs font-medium tracking-widest text-stone-400 uppercase"
    >
      Notes from early users
    </span>
    <h2 class="reveal mt-3 text-3xl font-medium tracking-tight md:text-5xl">
      Small wins, written
      <span
        class="text-[1.05em] leading-none"
        style="font-family: var(--font-cursive); color: #A8C9A0; font-weight: 400;"
      >
        down
      </span>
      somewhere.
    </h2>
    <p class="reveal text-muted mx-auto mt-5 max-w-xl text-base md:text-lg">
      Real entries from the private diary of youZen beta testers. Lightly edited
      for length. Not for applause — just proof you're not alone.
    </p>
  </div>

  <div class="mx-auto mt-16 grid max-w-4xl gap-6 md:grid-cols-2">
    {
      entries.map((e) => (
        <article
          class="reveal rounded-[2rem] border border-stone-100 bg-white p-7 shadow-softly transition-transform duration-500 hover:rotate-0"
          style={`transform: rotate(${e.tilt});`}
        >
          <p class="text-xs tracking-widest text-stone-400 uppercase">
            {e.date}
          </p>
          <p class="mt-4 text-base leading-relaxed text-stone-700 md:text-lg">
            {e.text}
          </p>
          <div class="mt-6 flex items-center gap-3">
            <span class="block h-px w-8 bg-stone-300" aria-hidden="true" />
            <span
              class="text-2xl leading-none text-stone-500"
              style="font-family: var(--font-cursive); font-weight: 400;"
            >
              {e.signature}
            </span>
          </div>
        </article>
      ))
    }
  </div>
</section>
