---
const year = new Date().getFullYear();
---

<footer class="relative px-6 pt-16 pb-10 text-sm text-stone-500">
  <div
    class="mx-auto flex max-w-5xl flex-col items-start justify-between gap-6 border-t border-stone-200/80 pt-10 md:flex-row md:items-center"
  >
    <div class="flex items-center gap-3">
      <span
        class="relative flex h-7 w-7 items-center justify-center rounded-full"
        style="background-color: #A8C9A0;"
        aria-hidden="true"
      >
        <span class="block h-2 w-2 rounded-full bg-white"></span>
      </span>
      <span class="text-ink font-medium">youZen</span>
      <span class="text-stone-400">·</span>
      <span>© {year}</span>
    </div>

    <nav
      class="flex flex-wrap items-center gap-x-6 gap-y-2 text-xs tracking-widest text-stone-400 uppercase"
    >
      <a href="#install" class="footer-link">Install</a>
      <a href="#faq" class="footer-link">FAQ</a>
      <a href="/privacy" class="footer-link">Privacy</a>
      <a href="https://github.com" class="footer-link" rel="noopener">Source</a>
    </nav>
  </div>

  <p class="mx-auto mt-8 max-w-5xl text-xs text-stone-400">
    Made slowly, on purpose.
  </p>
</footer>

<style>
  /* Mini version of the navbar's underline wipe — uppercase labels call
     for a tighter, single-color treatment. */
  .footer-link {
    position: relative;
    padding-bottom: 3px;
    transition: color 300ms ease;
    background-image: linear-gradient(
      to right,
      var(--color-leaf-deep),
      var(--color-leaf)
    );
    background-repeat: no-repeat;
    background-size: 0% 1.5px;
    background-position: 0 100%;
    transition:
      color 300ms ease,
      background-size 350ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .footer-link:hover,
  .footer-link:focus-visible {
    color: var(--color-ink);
    background-size: 100% 1.5px;
    outline: none;
  }
</style>
